{
  "name": "kernel-desk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "build:frontend": "npm --workspace frontend run build",
    "build:frontend:debug": "npm --workspace frontend run build:debug",
    "build:backend": "cd backend && gleam build",
    "check:backend": "cd backend && gleam check",
    "format:backend": "cd backend && gleam format src",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "node scripts/start.mjs",
    "dev": "npm run build:frontend:debug && npm run start",
    "verify:local": "node scripts/verify.mjs",
    "linux:clone": "node scripts/linux-repo.mjs clone",
    "linux:start": "node scripts/linux-repo.mjs start",
    "linux:dev": "node scripts/linux-repo.mjs dev"
  },
  "engines": {
    "node": ">=20"
  }
}
